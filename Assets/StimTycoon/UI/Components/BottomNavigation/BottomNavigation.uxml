<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:VisualElement name="bottom-navigation" class="st-life-bottom-nav st-component-bottom-nav">
        <ui:Button name="nav-life" class="st-life-nav-item stim-pack-interaction-pop active" tooltip="Life and Home"><ui:VisualElement class="st-nav-icon st-brand-space-icon icon-home" /><ui:Label text="Life" class="st-nav-label" /></ui:Button>
        <ui:Button name="nav-education" class="st-life-nav-item stim-pack-interaction-pop" tooltip="Education"><ui:VisualElement class="st-nav-icon st-brand-space-icon icon-book" /><ui:Label text="Study" class="st-nav-label" /></ui:Button>
        <ui:Button name="nav-career" class="st-life-nav-item stim-pack-interaction-pop" tooltip="Career and Business"><ui:VisualElement class="st-nav-icon st-brand-space-icon icon-rocket" /><ui:Label text="Work" class="st-nav-label" /></ui:Button>
        <ui:Button name="nav-money" class="st-life-nav-item stim-pack-interaction-pop" tooltip="Money and Banking"><ui:VisualElement class="st-nav-icon st-brand-space-icon icon-buy" /><ui:Label text="Bank" class="st-nav-label" /></ui:Button>
        <ui:Button name="nav-social" class="st-life-nav-item stim-pack-interaction-pop" tooltip="Social and Family"><ui:VisualElement class="st-nav-icon st-brand-space-icon icon-heart" /><ui:Label text="Social" class="st-nav-label" /></ui:Button>
        <ui:Button name="nav-goals" class="st-life-nav-item stim-pack-interaction-pop" tooltip="Goals and Legacy"><ui:VisualElement class="st-nav-icon st-brand-space-icon icon-trophy" /><ui:Label text="Goals" class="st-nav-label" /></ui:Button>
    </ui:VisualElement>
</ui:UXML>
