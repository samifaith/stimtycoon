}

.st-large-text .st-career-action {
    width: 100%;
    margin-right: 0;
}

.st-large-text .st-context-activity {
    width: 100%;
    margin-right: 0;
}

.st-large-text .st-option-row {
    flex-direction: column;
}

.st-large-text .st-setup-field {
    width: 100%;
    margin-right: 0;
    margin-bottom: 8px;
}

.st-large-text .st-option-button {
    width: 100%;
    margin-right: 0;
    margin-bottom: 8px;
}

.st-large-text .st-event-title {
    white-space: normal;
}

.st-large-text .st-ending-title {
    white-space: normal;
}

.st-large-text .st-social-title {
    white-space: normal;
}

.st-social-title {
    margin-top: 4px;
    color: rgb(7, 36, 82);
    font-size: 24px;
    -unity-font-style: bold;
    max-width: 100%;
    line-height: 28px;
    white-space: normal;
}

.st-age-progression {
    padding: 10px 12px;
}

.st-life-summary-content {
    max-width: 760px;
    align-self: center;
}

.st-life-summary-toolbar {
    min-height: 44px;
    margin-bottom: 5px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
}

.st-life-summary-back {
    min-width: 72px;
    min-height: 44px;
    padding: 0 10px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 12px;
    color: var(--st-cyan-700);
    font-size: 11px;
    -unity-font-style: bold;
}

.st-life-summary-details {
    min-width: 0;
}

.st-summary-detail-row {
    min-height: 32px;
    padding: 5px 0;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    border-bottom-width: 1px;
    border-bottom-color: var(--st-border-soft);
}

.st-summary-detail-label {
    width: 30%;
    min-width: 72px;
    color: var(--st-text-secondary);
    font-size: 10px;
}

.st-summary-detail-value {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    color: var(--st-text-primary);
    font-size: 11px;
    -unity-font-style: bold;
    -unity-text-align: middle-right;
    white-space: normal;
}

.st-age-strip-heading {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 9px;
}

.st-age-strip-summary {
    color: var(--color-text-secondary);
    font-size: 9px;
}

.st-age-stage-track {
    flex-direction: row;
    justify-content: space-between;
}

.st-age-stage {
    width: 24%;
    align-items: center;
}

.st-age-stage-icon {
    width: 30px;
    height: 30px;
    background-color: rgb(244,246,250);
    border-width: 2px;
    border-color: var(--color-disabled);
    border-radius: 15px;
    font-size: 15px;
    -unity-text-align: middle-center;
}

.st-age-stage-range {
    margin-top: 5px;
    color: var(--color-text-primary);
    font-size: 8px;
    -unity-font-style: bold;
}

.st-age-stage-name {
    margin-top: 2px;
    color: var(--color-text-secondary);
    font-size: 7px;
    -unity-text-align: middle-center;
}

.st-age-stage.complete .st-age-stage-icon {
    background-color: rgb(226,245,232);
    border-color: var(--color-green);
}

.st-age-stage.active .st-age-stage-icon {
    background-color: var(--color-primary-soft);
    border-color: var(--color-primary);
}

.st-age-stage.active .st-age-stage-name {
    color: var(--color-primary);
    -unity-font-style: bold;
}

.st-age-stage.locked {
    opacity: 0.55;
}

.st-destination-heading .st-social-title {
    margin-top: 0;
    font-size: 22px;
    line-height: 26px;
}

.st-destination-heading .st-social-subtitle {
    margin-top: 5px;
    margin-bottom: 0;
    font-size: 12px;
    line-height: 17px;
}

.st-social-subtitle {
    margin-top: 5px;
    margin-bottom: 10px;
    color: var(--st-text-secondary);
    font-size: 13px;
    white-space: normal;
    line-height: 18px;
}

.st-preview-panel {
    width: 100%;
    padding: 12px;
    background-color: var(--st-surface-1);
    border-width: 1px;
    border-color: var(--st-border-soft);
    border-radius: 16px;
}

.st-career-preview {
    width: 100%;
    padding: 12px;
    background-color: var(--st-surface-1);
    border-width: 1px;
    border-color: var(--st-border-soft);
    border-radius: 16px;
}

.st-preview-heading {
    flex-direction: row;
    align-items: center;
    margin-bottom: 10px;
}

.st-preview-heading-icon {
    width: 30px;
    height: 30px;
    margin-right: 8px;
    flex-shrink: 0;
    background-color: var(--st-cyan-600);
    border-radius: 15px;
    color: white;
    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
}

.st-preview-heading-title {
    color: rgb(7,36,82);
    font-size: 14px;
    -unity-font-style: bold;
}

.st-preview-label {
    margin-top: 4px;
    margin-bottom: 8px;
    color: rgb(7,36,82);
    font-size: 11px;
    letter-spacing: 0.5px;
    -unity-font-style: bold;
}

.st-manual-work-role {
    margin-top: 8px;
    color: var(--st-text-primary);
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    max-width: 100%;
    white-space: normal;
}

.st-worth-value {
    margin-top: 8px;
    color: rgb(7, 36, 82);
    font-size: 26px;
    -unity-font-style: bold;
    white-space: nowrap;
    overflow: hidden;
}

.st-social-discover {
    min-height: 50px;
    margin-bottom: 9px;
    background-color: var(--st-purple-500);
    border-width: 0;
    border-radius: 14px;
    color: var(--st-text-inverse);
    font-size: 11px;
    -unity-font-style: bold;
    padding-left: 8px;
    padding-right: 8px;
    white-space: normal;
}

.st-event-sheet {
    width: 100%;
    max-width: 440px;
    max-height: 720px;
    padding: 18px;
    flex-shrink: 1;
    background-color: var(--st-surface-1);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 24px;
}

.st-setup-sheet {
    width: 100%;
    max-width: 440px;
    max-height: 650px;
    padding: 18px;
    background-color: var(--st-surface-1);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 24px;
}

.st-setup-title {
    margin-top: 5px;
    color: rgb(7,36,82);
    font-size: 22px;
    -unity-font-style: bold;
    max-width: 100%;
    line-height: 27px;
    white-space: normal;
}

.st-event-title {
    margin-top: 5px;
    color: rgb(7,36,82);
    font-size: 22px;
    -unity-font-style: bold;
    max-width: 100%;
    line-height: 27px;
    white-space: normal;
}

.st-setup-body {
    margin-top: 6px;
    margin-bottom: 11px;
    color: var(--st-text-secondary);
    font-size: 13px;
    white-space: normal;
    line-height: 18px;
}

.st-event-body {
    margin-top: 7px;
    margin-bottom: 11px;
    color: var(--st-text-secondary);
    font-size: 13px;
    white-space: normal;
    line-height: 18px;
}

.st-generated-identity {
    min-height: 0;
    padding: 9px;
    flex-direction: row;
    align-items: center;
    background-color: var(--st-surface-blue);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 15px;
}

.st-background-title {
    color: var(--st-text-primary);
    font-size: 14px;
    -unity-font-style: bold;
    white-space: normal;
}

.st-background-detail {
    margin-top: 3px;
    color: var(--st-text-secondary);
    font-size: 11px;
    white-space: normal;
    line-height: 15px;
}

.st-setup-actions .unity-button {
    min-height: 44px;
    font-size: 12px;
}

.st-compact-width .st-social-title {
    font-size: 21px;
    line-height: 25px;
}

.st-compact-width .st-setup-title {
    font-size: 20px;
    line-height: 24px;
}

.st-compact-width .st-event-title {
    font-size: 20px;
    line-height: 24px;
}

.st-education-card .st-visual-slot-card {
    display: none;
}

.st-education-card .st-section-heading-icon {
    display: none;
}

.st-education-card .st-section-heading-title {
    font-size: 11px;
    letter-spacing: 0.5px;
}

.st-education-card .st-education-stage {
    margin-top: 2px;
    font-size: 12px;
    line-height: 16px;
}

.st-component-page-heading .st-social-title {
    -unity-font-definition: url("project://database/Assets/Skyden_Games/Free_Casual_GUI/Demo/Fonts/Baloo/Baloo-Regular.ttf");
    font-size: 20px;
    line-height: 23px;
}

.st-component-page-heading .st-social-subtitle {
    max-width: 250px;
    margin-top: 2px;
    font-size: 10px;
    line-height: 14px;
}

/* Full asset-kit integration for destination controls, sheets, and rewards. */
.st-asset-kits-integrated .st-focus-tile,
.st-asset-kits-integrated .st-context-activity,
.st-asset-kits-integrated .st-education-action,
.st-asset-kits-integrated .st-career-action,
.st-asset-kits-integrated .st-home-action,
.st-asset-kits-integrated .st-relationship-action,
.st-asset-kits-integrated .st-manual-work-button,
.st-asset-kits-integrated .st-social-discover,
.st-asset-kits-integrated .choice-button,
.st-asset-kits-integrated .st-advance-year,
.st-asset-kits-integrated .st-setup-continue {
    min-width: 0;
    min-height: 44px;
    padding: 9px 12px;
    background-color: rgb(255, 255, 255);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 22px;
    color: var(--st-text-primary);
    white-space: normal;
    -unity-text-align: middle-center;
    -unity-font-definition: url("project://database/Assets/Skyden_Games/Free_Casual_GUI/Demo/Fonts/Baloo/Baloo-Regular.ttf");
}

.st-asset-kits-integrated .st-advance-month,
.st-asset-kits-integrated .st-event-continue,
.st-asset-kits-integrated .st-setup-create,
.st-asset-kits-integrated .st-ending-action {
    min-width: 0;
    min-height: 44px;
    padding: 9px 12px;
    background-color: var(--st-cyan-600);
    border-width: 0;
    border-radius: 22px;
    color: white;
    white-space: normal;
    -unity-text-align: middle-center;
    -unity-font-definition: url("project://database/Assets/Skyden_Games/Free_Casual_GUI/Demo/Fonts/Baloo/Baloo-Regular.ttf");
}

.st-asset-kits-integrated .st-segmented-tab,
.st-asset-kits-integrated .st-transfer-mode,
.st-asset-kits-integrated .st-setup-cancel,
.st-asset-kits-integrated .st-social-back,
.st-asset-kits-integrated .st-icon-button,
.st-asset-kits-integrated .st-new-life-link {
    min-width: 0;
    min-height: 44px;
    padding: 9px 12px;
    background-color: rgb(255, 246, 241);
    border-width: 1px;
    border-color: rgb(219, 195, 167);
    border-radius: 18px;
    color: var(--st-text-primary);
    white-space: normal;
    -unity-text-align: middle-center;
}

.st-asset-kits-integrated .st-segmented-tab.active,
.st-asset-kits-integrated .st-transfer-mode.active {
    background-color: var(--st-cyan-600);
    border-color: var(--st-cyan-600);
    color: white;
}

.st-asset-kits-integrated .st-event-sheet,
.st-asset-kits-integrated .st-setup-sheet,
.st-asset-kits-integrated .st-ending-card {
    min-width: 0;
    background-color: rgb(255, 255, 255);
    border-width: 1px;
    border-color: var(--st-border-soft);
    border-radius: 20px;
    padding: 22px;
}

.st-asset-kits-integrated .st-result-card {
    border-width: 3px;
    border-color: var(--stim-pack-reward);
    background-color: rgb(255, 245, 251);
}

/* Responsive Stim controls own their full bounds, so labels wrap inside them. */
.st-asset-kits-integrated .st-focus-title {
    color: var(--st-text-primary);
    max-width: 100%;
    white-space: normal;
    -unity-text-align: middle-left;
}

.st-asset-kits-integrated .st-focus-effect {
    color: var(--st-text-secondary);
    max-width: 100%;
    white-space: normal;
    -unity-text-align: middle-right;
}

.st-asset-kits-integrated .st-focus-cta {
    color: var(--st-text-inverse);
    max-width: 100%;
    white-space: normal;
    -unity-text-align: middle-center;
}

.st-asset-kits-integrated .st-focus-tile.study {
    background-color: var(--st-surface-blue);
    border-color: var(--st-border-blue);
}

.st-asset-kits-integrated .st-focus-tile.workout {
    background-color: var(--st-surface-pink);
    border-color: var(--st-border-pink);
}

.st-asset-kits-integrated .st-focus-tile.work {
    background-color: var(--st-surface-yellow);
    border-color: var(--st-border-yellow);
}

.st-asset-kits-integrated .st-social-discover,
.st-asset-kits-integrated .st-advance-year {
    background-color: var(--st-purple-500);
    border-width: 0;
    color: var(--st-text-inverse);
}

.st-asset-kits-integrated .st-manual-work-button {
    background-color: var(--st-success-500);
    border-width: 0;
    color: var(--st-text-inverse);
}

/* Harmonize Stim-owned detail rows and setup controls with the live kit layer. */
.st-asset-kits-integrated .st-skill-row,
.st-asset-kits-integrated .st-summary-detail-row,
.st-asset-kits-integrated .st-money-history-row {
    margin-bottom: 6px;
    padding: 8px 10px;
    background-color: rgba(255, 255, 255, 0.88);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 14px;
}

.st-asset-kits-integrated .st-generated-identity {
    background-color: var(--st-surface-blue);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 18px;
}

.st-asset-kits-integrated .st-result-effects {
    background-color: rgba(255, 255, 255, 0.94);
    border-width: 1px;
    border-color: var(--st-border-pink);
    border-radius: 14px;
}

.st-asset-kits-integrated .st-generated-icon,
.st-asset-kits-integrated .st-preview-heading-icon {
    height: 34px;
    background-color: var(--st-surface-purple);
    border-width: 1px;
    border-color: var(--st-border-purple);
    border-radius: 12px;
    color: var(--st-purple-600);
}

.st-asset-kits-integrated .st-age-stage-icon {
    width: 32px;
    height: 32px;
    background-color: var(--st-surface-blue);
    border-width: 2px;
    border-color: var(--st-border-blue);
    border-radius: 16px;
}

.st-asset-kits-integrated .st-age-stage.complete .st-age-stage-icon {
    background-color: rgb(232, 248, 236);
    border-color: var(--st-success-500);
}

.st-asset-kits-integrated .st-age-stage.active .st-age-stage-icon {
    background-color: var(--st-surface-purple);
    border-color: var(--st-purple-500);
}

.st-asset-kits-integrated .st-setup-field .unity-base-text-field__input {
    min-width: 0;
    min-height: 44px;
    padding: 9px 18px;
    background-color: white;
    border-width: 2px;
    border-color: var(--st-border-purple);
    border-radius: 14px;
}

.st-asset-kits-integrated .st-option-button,
.st-asset-kits-integrated .st-background-option {
    background-color: rgba(255, 255, 255, 0.9);
    border-width: 1px;
    border-color: var(--st-border-blue);
    border-radius: 16px;
}

.st-asset-kits-integrated .st-option-button:hover,
.st-asset-kits-integrated .st-option-button:focus,
.st-asset-kits-integrated .st-background-option:hover,
.st-asset-kits-integrated .st-background-option:focus {
    background-color: var(--st-surface-blue);
    border-color: var(--st-cyan-600);
}

.st-jelly-result-mark {
    width: 36px;
    height: 36px;
    align-self: center;
    margin-bottom: 4px;
    background-image: url("project://database/Assets/Jelly_UI_Pack/Sprites/Icons/star_icon.png");
    -unity-background-scale-mode: scale-to-fit;
}

.st-asset-kits-integrated Button:hover,
.st-asset-kits-integrated Button:focus {
    -unity-background-image-tint-color: rgb(255, 246, 224);
}

.st-asset-kits-integrated Button:active {
    opacity: 0.84;
}

.st-asset-kits-integrated Button:disabled {
    opacity: 0.45;
}
