# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/

# Generated Unity/Yarn editor state
/ProjectSettings/SceneTemplateSettings.json
/ProjectSettings/Packages/dev.yarnspinner/*-generated.ysls.json
/ProjectSettings/Packages/com.unity.ai.assistant/

# Deferred package integration artifacts
# LevelPlay/IAP production configuration is intentionally deferred until M18.
/Assets/MobileDependencyResolver/
/Assets/MobileDependencyResolver.meta
/Assets/Resources/BillingMode.json
/Assets/Resources/BillingMode.json.meta

# Do not accidentally embed Unity's registry-owned simulator device catalog.
/Packages/com.unity.device-simulator.devices/

# Unity asset meta cache
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt

# Autogenerated VS/MD/Consulo/Rider files
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.idea/
.vscode/

# OS/editor files
.DS_Store
Thumbs.db
*.swp
*.swo

# Unity Addressables build data
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Keep Unity metadata tracked for project assets
!*.meta

# These metadata files belong only to the deferred generated artifacts above.
/Assets/MobileDependencyResolver.meta
/Assets/Resources.meta
/Assets/Resources/BillingMode.json.meta
